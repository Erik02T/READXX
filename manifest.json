{
  "manifest_version": 3,
  "name": "readxx",
  "version": "0.1.0",
  "description": "Personal reading assistant with vocabulary builder",

  "permissions": [
    "storage",
    "unlimitedStorage",
    "alarms",
    "sidePanel",
    "activeTab"
  ],

  "host_permissions": [
    "https://api.readxx.app/*"
  ],

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "readxx"
  },

  "side_panel": {
    "default_path": "sidepanel/sidepanel.html"
  },

  "background": {
    "service_worker": "background/sw.ts",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "js": ["src/content/index.ts"],
      "run_at": "document_idle",
      "world": "ISOLATED"
    }
  ],

  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src https://api.readxx.app; default-src 'self'; frame-ancestors 'none'"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "icons/*.png",
        "icons/*.svg"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16": "/icons/icon-16.png",
    "48": "/icons/icon-48.png",
    "128": "/icons/icon-128.png"
  }
}
